{
  "name": "vite-ts-starter",
  "description": "🐬 A Starter template built on Vite 7.x + Vue 3.x + Element Plus 2.x + TypeScript.",
  "version": "0.0.1",
  "author": "Wisdom <pdsu.wwz@foxmail.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build --mode prod",
    "deploy:gh-pages": "cross-env VITE_ROUTER_MODE=hash pnpm build",
    "preview": "vite preview --host",
    "lint": "oxlint --vue-plugin .",
    "lint:fix": "oxlint --vue-plugin --fix .",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "stylelint": "stylelint \"src/**/*.{css,scss,vue}\"",
    "stylelint:fix": "stylelint \"src/**/*.{css,scss,vue}\" --fix",
    "template:check": "node scripts/check-template.cjs",
    "init:template": "node scripts/bootstrap-template.cjs",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22.13.x",
    "pnpm": ">= 9.x"
  },
  "keywords": [
    "vue",
    "vue3",
    "vue-next",
    "vite",
    "jest",
    "vitest",
    "typescript",
    "admin",
    "example",
    "template",
    "dashboard",
    "framework",
    "prototyping",
    "element-plus",
    "admin-template"
  ],
  "homepage": "https://github.com/NorthEgg/vite-ts-starter",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NorthEgg/vite-ts-starter"
  },
  "bugs": {
    "url": "https://github.com/NorthEgg/vite-ts-starter/issues"
  },
  "dependencies": {
    "@element-plus/icons-vue": "2.3.2",
    "axios": "1.18.0",
    "echarts": "^6.1.0",
    "element-plus": "2.14.2",
    "js-cookie": "^3.0.8",
    "lodash-es": "^4.18.1",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.38",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@iconify/json": "^2.2.488",
    "@iconify/vue": "^5.0.1",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.9.1",
    "@types/nprogress": "^0.2.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/compiler-sfc": "^3.5.38",
    "@vue/test-utils": "2.4.11",
    "babel-plugin-transform-vite-meta-env": "^1.0.3",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "postcss": "^8.5.15",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "rollup": "4.62.2",
    "sass": "1.101.0",
    "stylelint": "^17.13.0",
    "stylelint-config-recommended-scss": "^17.0.1",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "17.0.0",
    "terser": "^5.48.0",
    "typescript": "^6.0.3",
    "unocss": "66.7.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.16",
    "vite-plugin-vue-devtools": "^8.1.3",
    "vitest": "^4.1.9",
    "vue-component-type-helpers": "^3.3.5",
    "vue-tsc": "^3.3.5"
  }
}
