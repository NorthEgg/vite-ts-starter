{
  "name": "vite-ts-starter",
  "description": "🐬 A Starter template built on Vite 7.x + Vue 3.x + Element Plus 2.x + TypeScript.",
  "version": "0.0.1",
  "author": "Wisdom <pdsu.wwz@foxmail.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build --mode prod",
    "deploy:gh-pages": "cross-env VITE_ROUTER_MODE=hash pnpm build",
    "preview": "vite preview --host",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "format": "prettier --write \"**/*.{json,md,html,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{json,md,html,yml,yaml}\"",
    "stylelint": "stylelint .scss, .vue ./src",
    "stylelint:fix": "stylelint --fix .scss, .vue ./src",
    "template:check": "node scripts/check-template.cjs",
    "init:template": "node scripts/bootstrap-template.cjs",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22.12.x",
    "pnpm": ">= 9.x"
  },
  "keywords": [
    "vue",
    "vue3",
    "vue-next",
    "vite",
    "jest",
    "vitest",
    "typescript",
    "admin",
    "example",
    "template",
    "dashboard",
    "framework",
    "prototyping",
    "element-plus",
    "admin-template"
  ],
  "homepage": "https://github.com/NorthEgg/vite-ts-starter",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NorthEgg/vite-ts-starter"
  },
  "bugs": {
    "url": "https://github.com/NorthEgg/vite-ts-starter/issues"
  },
  "dependencies": {
    "@element-plus/icons-vue": "2.3.2",
    "axios": "1.16.1",
    "echarts": "^6.1.0",
    "element-plus": "2.14.0",
    "js-cookie": "^3.0.7",
    "lodash-es": "^4.18.1",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "@iconify/json": "^2.2.480",
    "@iconify/vue": "^5.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@stylistic/stylelint-plugin": "^5.2.0",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.9.1",
    "@types/nprogress": "^0.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.7",
    "@vue/compiler-sfc": "^3.5.35",
    "@vue/test-utils": "2.4.10",
    "babel-plugin-transform-vite-meta-env": "^1.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.0",
    "eslint-plugin-html": "8.1.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "10.9.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "postcss": "^8.5.15",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.3",
    "rollup": "4.60.4",
    "sass": "1.100.0",
    "stylelint": "^17.12.0",
    "stylelint-config-recommended-scss": "^17.0.1",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "17.0.0",
    "typescript": "^6.0.3",
    "unocss": "66.7.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "vue-component-type-helpers": "^3.3.2",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.3.2"
  }
}
